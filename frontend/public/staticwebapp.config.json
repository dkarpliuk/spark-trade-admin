{
  "auth": {
    "rolesSource": "/api/GetRoles"
  },
  "routes": [
    { "route": "/api/GetRoles", "allowedRoles": ["anonymous"] },
    { "route": "/api/*", "allowedRoles": ["admin"] },
    { "route": "/*", "allowedRoles": ["admin"] }
  ],
  "responseOverrides": {
    "401": {
      "redirect": "/.auth/login/github",
      "statusCode": 302
    }
  }
}
